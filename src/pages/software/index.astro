---
import BaseLayout from '../../layouts/BaseLayout.astro'
import SoftwareGrid from '../../components/SoftwareGrid.astro'
import PageHeader from '../../components/PageHeader.astro'
const title = 'Software'
const description = 'The open-source Metanorma toolchain'
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-[1200px] px-6 py-12">
    <PageHeader title={title} description={description} />
    <p class="mb-8 text-[var(--mn-c-text-2)]">
      The Metanorma toolchain is a collection of open-source Ruby gems and tools for authoring, compiling, and publishing standards documents.
    </p>
    <SoftwareGrid />
  </div>
</BaseLayout>
