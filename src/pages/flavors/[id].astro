---
import type { GetStaticPaths } from 'astro'
import { getEntry } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import FlavorPage from '../../components/FlavorPage.astro'
import Sidebar from '../../components/Sidebar.astro'
import TOC from '../../components/TOC.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import MirrorContent from '../../components/MirrorContent.astro'
import { flavors } from '../../data/flavors'
import type { MirrorEntry } from '../../content/loaders/mirror-loader'

export const getStaticPaths = (async () => {
  return flavors.map(flavor => ({
    params: { id: flavor.id },
    props: { flavor },
  }))
}) satisfies GetStaticPaths

interface Props {
  flavor: typeof flavors[number]
}
const { flavor } = Astro.props as Props
const pathname = `/flavors/${flavor.id}/`
const landingSlug = `flavors/${flavor.id}`
const entry = await getEntry('mirror', landingSlug) as { data: MirrorEntry } | null
const landing = entry?.data
const tocItems = landing?.headings.filter(h => h.depth >= 2 && h.depth <= 4) ?? []
const hasToc = tocItems.length >= 2
---

<BaseLayout title={flavor.fullName} description={flavor.description}>
  <div class="mx-auto grid max-w-[1440px] gap-8 px-6 pb-8 grid-cols-1 lg:grid-cols-[288px_minmax(0,1fr)] xl:grid-cols-[288px_minmax(0,1fr)_224px]">
    <Sidebar pathname={pathname} />
    <div class="mn-content-area">
      {hasToc && <TOC headings={landing!.headings} variant="mobile" />}
      <div class="px-2 pt-4">
        <Breadcrumb pathname={pathname} />
      </div>
      <FlavorPage flavor={flavor}>
        {landing && landing.rendered_html && (
          <section class="mt-8">
            <MirrorContent html={landing.rendered_html} />
          </section>
        )}
      </FlavorPage>
    </div>
    {hasToc && <TOC headings={landing!.headings} variant="desktop" />}
  </div>
</BaseLayout>
