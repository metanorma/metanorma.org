---
import BaseLayout from '../layouts/BaseLayout.astro'
import { homeData as d } from '../data/home'
import { flavors } from '../data/flavors'
import { posts } from '../data/posts'
import { formatDate } from '../lib/format-date'
const allFlavors = flavors
---

<BaseLayout title={d.hero.titleLine1 + ' ' + d.hero.titleLine2} description={d.hero.subtitle}>
  <!-- ═══ HERO ═══ -->
  <section class="mn-grain relative overflow-hidden">
    <!-- Ambient background: gradient mesh + glow -->
    <div class="pointer-events-none absolute inset-0 z-0">
      <div class="absolute inset-0 bg-gradient-to-b from-[var(--mn-c-bg-soft)] via-[var(--mn-c-bg)] to-[var(--mn-c-bg)]"></div>
      <div class="mn-glow-pulse absolute -right-32 -top-32 h-[500px] w-[500px] rounded-full blur-3xl" style="background: radial-gradient(circle, var(--mn-c-brand-glow), transparent 65%);"></div>
      <div class="absolute -bottom-40 -left-20 h-[400px] w-[400px] rounded-full opacity-[0.04] blur-3xl" style="background: radial-gradient(circle, var(--mn-c-brand-1), transparent 60%);"></div>
    </div>

    <div class="relative z-10 mx-auto grid max-w-[1320px] items-center gap-16 px-6 py-24 lg:grid-cols-[1.1fr_0.9fr] lg:py-32">
      <!-- ▸ LEFT — Editorial -->
      <div>
        <!-- Headline -->
        <h1 class="mn-rise text-[clamp(2.75rem,7vw,5.5rem)] font-extrabold leading-[0.92] tracking-[-0.035em] text-[var(--mn-c-text-1)]" style="animation-delay: 0.1s;">
          {d.hero.titleLine1}
          <span class="block font-extralight text-[var(--mn-c-brand-1)]">{d.hero.titleLine2}</span>
        </h1>

        <!-- Subtitle -->
        <p class="mn-rise mt-8 max-w-[480px] text-lg leading-[1.65] text-[var(--mn-c-text-2)]" style="animation-delay: 0.2s;">
          {d.hero.subtitle}
        </p>

        <!-- CTAs -->
        <div class="mn-rise mt-10 flex flex-wrap items-center gap-4" style="animation-delay: 0.3s;">
          <a href={d.hero.primaryAction.href} class="group inline-flex items-center gap-2 rounded-full bg-[var(--mn-c-brand-1)] px-7 py-3.5 text-sm font-semibold text-white no-underline transition-all duration-300 hover:shadow-xl hover:shadow-[var(--mn-c-brand-1)]/25">
            {d.hero.primaryAction.label}
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href={d.hero.secondaryAction.href} class="inline-flex items-center gap-2 rounded-full border border-[var(--mn-c-divider)] px-7 py-3.5 text-sm font-semibold text-[var(--mn-c-text-1)] no-underline transition-all duration-300 hover:border-[var(--mn-c-brand-1)] hover:text-[var(--mn-c-brand-1)]">
            {d.hero.secondaryAction.label}
          </a>
        </div>
      </div>

      <!-- ▸ RIGHT — Large brand icon -->
      <div class="mn-rise relative flex items-center justify-center" style="animation-delay: 0.4s;">
        <div class="mn-glow-pulse absolute inset-0 rounded-full blur-3xl" style="background: radial-gradient(circle, var(--mn-c-brand-glow), transparent 65%);"></div>
        <div class="mn-hero-float relative">
          <img src="/metanorma-logo_icon-light.svg" alt="Metanorma" class="h-64 w-64 dark:hidden md:h-80 md:w-80 lg:h-96 lg:w-96" />
          <img src="/metanorma-logo_icon-dark.svg" alt="Metanorma" class="hidden h-64 w-64 dark:block md:h-80 md:w-80 lg:h-96 lg:w-96" />
        </div>
      </div>
    </div>

    <!-- ▸ Create your flavor -->
    <div class="relative z-10 mx-auto max-w-[1320px] px-6 py-16">
      <div class="mn-grain relative overflow-hidden rounded-3xl border border-[var(--mn-c-divider)] bg-[var(--mn-c-bg-elv)] px-8 py-10 md:px-12 md:py-12">
        <div class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full opacity-[0.05] blur-3xl" style="background: radial-gradient(circle, var(--mn-c-brand-glow), transparent);"></div>
        <div class="relative flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
          <div>
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-[var(--mn-c-brand-1)]">
              For your organization
            </p>
            <h2 class="mt-2 text-2xl font-bold leading-tight text-[var(--mn-c-text-1)] md:text-3xl">
              Build a custom flavor
            </h2>
            <p class="mt-2 max-w-md text-[var(--mn-c-text-2)]">Tailor Metanorma to your SDO's specific formatting, validation, and output requirements.</p>
          </div>
          <a href="/develop/topics/adopting-toolchain/" class="group flex flex-shrink-0 items-center gap-2 rounded-full bg-[var(--mn-c-brand-1)] px-7 py-3.5 text-sm font-semibold text-white no-underline shadow-lg shadow-[var(--mn-c-brand-1)]/20 transition-all duration-300 hover:shadow-xl">
            Create your flavor
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FLAVORS ═══ -->
  <section class="mx-auto max-w-[1320px] px-6 py-20">
    <div class="mb-10">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-[var(--mn-c-brand-1)]">{allFlavors.length} flavors</p>
      <h2 class="mt-3 text-3xl font-bold text-[var(--mn-c-text-1)] md:text-4xl">Supported organizations</h2>
      <p class="mt-2 max-w-2xl text-[var(--mn-c-text-2)]">Spanning international, regional, national, and industry standards bodies.</p>
    </div>
    <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5">
      {allFlavors.map((flavor, i) => (
        <a
          href={`/flavors/${flavor.id}/`}
          class={`mn-rise group relative flex flex-col items-center justify-center gap-2 rounded-xl border border-[var(--mn-c-divider)] bg-[var(--mn-c-bg-elv)] px-4 py-3 text-center no-underline transition-all duration-300 hover:border-[var(--mn-c-brand-1)] hover:shadow-lg ${flavor.logoLight && !flavor.logoDark ? 'dark:bg-[#e8e8e8] dark:border-transparent' : ''}`}
          title={flavor.description}
          style={`animation-delay: ${i * 0.04}s;`}
        >
          <div class="flex h-14 items-center justify-center">
            {flavor.logoLight
              ? (<>
                <img src={flavor.logoLight} alt={flavor.label} class="h-12 max-w-full object-contain transition-transform duration-300 group-hover:scale-110 dark:hidden" />
                {flavor.logoDark
                  ? <img src={flavor.logoDark} alt={flavor.label} class="hidden h-12 max-w-full object-contain transition-transform duration-300 group-hover:scale-110 dark:block" />
                  : <img src={flavor.logoLight} alt={flavor.label} class="hidden h-12 max-w-full object-contain transition-transform duration-300 group-hover:scale-110 dark:block" />}
              </>)
            : flavor.logo
              ? <img src={flavor.logo} alt={flavor.label} class={`h-12 max-w-full object-contain transition-transform duration-300 group-hover:scale-110 ${flavor.logoInvert ? 'dark:invert' : ''}`} />
              : <span class="text-3xl font-bold text-[var(--mn-c-brand-1)]" style="font-family: var(--mn-font-display);">{flavor.label.charAt(0)}</span>}
          </div>
          <span class={`text-sm font-semibold ${flavor.logoLight && !flavor.logoDark ? 'dark:text-gray-800' : 'text-[var(--mn-c-text-1)]'}`}>{flavor.label}</span>
          {flavor.status === 'experimental' && <span class="absolute right-2 top-2 rounded-full bg-amber-500/15 px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-amber-600">Beta</span>}
          {flavor.status === 'private' && <span class="absolute right-2 top-2 rounded-full bg-[var(--mn-c-bg-mute)] px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-[var(--mn-c-text-3)]">Private</span>}
        </a>
      ))}
    </div>
  </section>

  <!-- ═══ PIPELINE ═══ -->
  <section class="mx-auto max-w-[1320px] px-6 py-20">
    <div class="mb-10 text-center">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-[var(--mn-c-brand-1)]">How it works</p>
      <h2 class="mt-3 text-3xl font-bold text-[var(--mn-c-text-1)] md:text-4xl">From source to published standard</h2>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {d.pipeline.map((step, i) => (
        <a href={step.link} class="mn-rise group relative overflow-hidden rounded-2xl border border-[var(--mn-c-divider)] bg-[var(--mn-c-bg-elv)] p-7 no-underline transition-all duration-300 hover:border-[var(--mn-c-brand-1)] hover:shadow-lg" style={`animation-delay: ${i * 0.1}s;`}>
          <div class="pointer-events-none absolute -right-8 -top-8 text-[80px] font-black leading-none text-[var(--mn-c-bg-soft)] transition-colors group-hover:text-[var(--mn-c-brand-soft)]" style="font-family: var(--mn-font-display);">{step.number}</div>
          <div class="relative">
            <span class="text-xs font-bold uppercase tracking-wider text-[var(--mn-c-brand-1)]">Step {step.number}</span>
            <h3 class="mt-2 text-xl font-bold text-[var(--mn-c-text-1)]">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-[var(--mn-c-text-2)]">{step.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ═══ RECENT POSTS ═══ -->
  <section class="mx-auto max-w-[1320px] px-6 py-20">
    <div class="mb-10 flex items-end justify-between">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.25em] text-[var(--mn-c-brand-1)]">Latest news</p>
        <h2 class="mt-3 text-3xl font-bold text-[var(--mn-c-text-1)] md:text-4xl">From the blog</h2>
      </div>
      <a href="/blog/" class="group flex items-center gap-1.5 text-sm font-semibold text-[var(--mn-c-brand-1)] no-underline">
        All posts
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>
    <div class="grid gap-5 md:grid-cols-3">
      {posts.slice(0, 3).map((post, i) => (
        <a href={post.url} class="mn-rise group flex flex-col rounded-2xl border border-[var(--mn-c-divider)] bg-[var(--mn-c-bg-elv)] p-6 no-underline transition-all duration-300 hover:border-[var(--mn-c-brand-1)] hover:shadow-lg" style={`animation-delay: ${i * 0.1}s;`}>
          <time class="text-xs font-medium uppercase tracking-wider text-[var(--mn-c-text-3)]">{formatDate(post.date)}</time>
          <h3 class="mt-3 text-lg font-bold leading-snug text-[var(--mn-c-text-1)] transition-colors group-hover:text-[var(--mn-c-brand-1)]">{post.title}</h3>
          {post.description && <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-[var(--mn-c-text-2)]">{post.description}</p>}
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
