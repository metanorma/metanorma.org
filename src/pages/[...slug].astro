---
import type { GetStaticPaths } from 'astro'
import { getCollection, type CollectionEntry } from 'astro:content'
import BaseLayout from '../layouts/BaseLayout.astro'
import Article from '../components/Article.astro'
import MirrorContent from '../components/MirrorContent.astro'
import Sidebar from '../components/Sidebar.astro'
import TOC from '../components/TOC.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import PrevNext from '../components/PrevNext.astro'
import { sidebarFor } from '../config/site'
import { flavors } from '../data/flavors'
import { hasToc } from '../lib/toc'
import { getNavTrees } from '../lib/nav-tree'
import { buildCrumbs } from '../lib/breadcrumbs'
import { ATTRIBUTE_PAGES } from '../lib/attr-registry'
import { editUrlFor, lastmodFor } from '../lib/source-meta'

export const getStaticPaths = (async () => {
  const entries = await getCollection('mirror')
  // Named routes always win over this catch-all: blog/index.astro serves
  // /blog/, software/index.astro serves /software/, flavors/index.astro
  // serves /flavors/, and flavors/[id].astro serves /flavors/<id>/ for
  // every catalog flavor. The attribute reference pages are served from
  // attributes/*.yaml manifests by their own named routes (see
  // src/lib/attr-registry.ts) — their mirror envelopes are superseded
  // but, until pruned, would still collide here. Skip all of these so
  // the catch-all doesn't emit shadowed pages (route-conflict warnings).
  const shadowed = new Set([
    'blog', 'software', 'flavors',
    ...flavors.map(f => `flavors/${f.id}`),
    ...ATTRIBUTE_PAGES.map(p => p.urlPath),
  ])
  return entries
    // blog/* entries are served by blog/[...slug].astro — emitting them
    // here too would produce route-conflict warnings on every build.
    .filter((entry: CollectionEntry<'mirror'>) =>
      !shadowed.has(entry.id) && !entry.id.startsWith('blog/'))
    .map((entry: CollectionEntry<'mirror'>) => ({
      params: { slug: entry.id },
      props: { entry },
    }))
}) satisfies GetStaticPaths

interface Props { entry: CollectionEntry<'mirror'> }
const { entry } = Astro.props as Props
// entry.data conforms to mirrorEntrySchema (src/lib/mirror-schema.ts) —
// the one envelope model. No inline shape re-assertion.
const { title, frontmatter, headings, rendered_html, source } = entry.data
const subtitle = frontmatter.subtitle || frontmatter.description || ''
const pathname = Astro.url.pathname
// The page resolves the nav tree ONCE and hands it to Sidebar and
// Breadcrumb as props.
const nav = sidebarFor(pathname)
const showToc = hasToc(headings)
const hasSidebar = nav !== null && nav.items.length > 0
const editUrl = editUrlFor(source)
const modifiedAt = lastmodFor(source)
// Prev/next pagination is a /learn/ feature: the sequence is the course
// order declared in learn/_nav.yml (the learn ROOT tree — lesson pages
// resolve the /learn/lessons/ sidebar tree, whose item order is not the
// reading order, so pagination must not use it).
const learnNav = pathname.startsWith('/learn/')
  ? getNavTrees().find(t => t.prefix === '/learn/') ?? null
  : null
---

<BaseLayout title={title} frontmatter={frontmatter} crumbs={buildCrumbs(nav, pathname)} modifiedAt={modifiedAt}>
  {hasSidebar ? (
    <div class="mx-auto grid max-w-[1440px] gap-8 px-6 pb-8 grid-cols-1 lg:grid-cols-[288px_minmax(0,1fr)] xl:grid-cols-[288px_minmax(0,1fr)_224px]">
      <Sidebar nav={nav} pathname={pathname} />
      <div class="mn-content-area">
        {showToc && <TOC headings={headings} variant="mobile" />}
        <div class="px-2 pt-4">
          <Breadcrumb nav={nav} pathname={pathname} />
        </div>
        <Article title={title} subtitle={subtitle} editUrl={editUrl}>
          <MirrorContent html={rendered_html} />
          {learnNav && <PrevNext nav={learnNav} pathname={pathname} />}
        </Article>
      </div>
      {showToc && <TOC headings={headings} variant="desktop" />}
    </div>
  ) : showToc ? (
    <div class="mx-auto grid max-w-[1440px] gap-8 px-6 pb-8 grid-cols-1 lg:grid-cols-[minmax(0,1fr)_224px]">
      <div>
        <TOC headings={headings} variant="mobile" bp="lg" />
        <Article class="mn-rendered mx-auto max-w-3xl px-2 py-12" title={title} subtitle={subtitle} editUrl={editUrl}>
          <Breadcrumb slot="breadcrumb" nav={nav} pathname={pathname} />
          <MirrorContent html={rendered_html} />
          {learnNav && <PrevNext nav={learnNav} pathname={pathname} />}
        </Article>
      </div>
      <TOC headings={headings} variant="desktop" bp="lg" />
    </div>
  ) : (
    <Article class="mn-rendered mx-auto max-w-3xl px-6 py-12" title={title} subtitle={subtitle} editUrl={editUrl}>
      <Breadcrumb slot="breadcrumb" nav={nav} pathname={pathname} />
      <MirrorContent html={rendered_html} />
      {learnNav && <PrevNext nav={learnNav} pathname={pathname} />}
    </Article>
  )}
</BaseLayout>
