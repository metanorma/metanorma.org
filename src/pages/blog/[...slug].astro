---
import type { GetStaticPaths } from 'astro'
import { getCollection, type CollectionEntry } from 'astro:content'
import BaseLayout from '../../layouts/BaseLayout.astro'
import BlogPostArticle from '../../components/BlogPostArticle.astro'
import TOC from '../../components/TOC.astro'
import { formatDate } from '../../lib/format-date'
import { hasToc } from '../../lib/toc'
import type { MirrorFrontmatterAuthor } from '../../lib/mirror-schema'

export const getStaticPaths = (async () => {
  const entries = await getCollection('mirror')
  return entries
    .filter((entry: CollectionEntry<'mirror'>) => entry.id.startsWith('blog/'))
    .map((entry: CollectionEntry<'mirror'>) => ({
      params: { slug: entry.id.replace(/^blog\//, '') },
      props: { entry },
    }))
}) satisfies GetStaticPaths

interface Props { entry: CollectionEntry<'mirror'> }
const { entry } = Astro.props as Props
// entry.data conforms to mirrorEntrySchema (src/lib/mirror-schema.ts) —
// the one envelope model. No inline shape re-assertion.
const { title, frontmatter, headings, rendered_html } = entry.data
const date = frontmatter.date ? formatDate(String(frontmatter.date)) : ''
const isoDate = frontmatter.date ? String(frontmatter.date).slice(0, 10) : ''
const author: MirrorFrontmatterAuthor = frontmatter.author ?? {}
const desc = frontmatter.excerpt || frontmatter.description || ''
const authorPicture = author.use_picture ? `/assets/${author.use_picture.replace(/^assets\/?/, '')}` : null
const showToc = hasToc(headings)
---

<BaseLayout title={title} description={desc} frontmatter={frontmatter} publishedAt={isoDate} crumbs={[
  { label: 'Blog', href: '/blog/', isLast: false },
  { label: title, href: Astro.url.pathname, isLast: true },
]}>
  {showToc && <TOC headings={headings} variant="mobile" />}
  {showToc ? (
    <div class="flex gap-8 pb-16">
      <BlogPostArticle
        class="mx-auto max-w-2xl min-w-0 flex-1 px-6 pt-8"
        title={title}
        date={date}
        isoDate={isoDate}
        desc={desc}
        author={author}
        authorPicture={authorPicture}
        html={rendered_html}
      />
      <TOC headings={headings} variant="desktop" />
    </div>
  ) : (
    <BlogPostArticle
      class="mx-auto max-w-2xl px-6 pt-16 pb-16"
      title={title}
      date={date}
      isoDate={isoDate}
      desc={desc}
      author={author}
      authorPicture={authorPicture}
      html={rendered_html}
    />
  )}
</BaseLayout>
