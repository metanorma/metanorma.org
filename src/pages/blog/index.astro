---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PageHeader from '../../components/PageHeader.astro'
import BlogPostCard from '../../components/BlogPostCard.astro'
import Pagination from '../../components/Pagination.astro'
import { posts } from '../../data/posts'

const PAGE_SIZE = 10
const totalPages = Math.ceil(posts.length / PAGE_SIZE)
const firstPage = posts.slice(0, PAGE_SIZE)
const title = 'Blog'
const description = 'News, releases, and articles from the Metanorma team'
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-[800px] px-6 py-12">
    <PageHeader title={title} />
    <div class="flex flex-col gap-4">
      {firstPage.map(post => <BlogPostCard post={post} />)}
    </div>
    {totalPages > 1 && <Pagination currentPage={1} lastPage={totalPages} nextUrl="/blog/page/2/" />}
  </div>
</BaseLayout>
