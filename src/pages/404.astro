---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Not Found" description="The page you requested does not exist.">
  <div class="flex flex-col items-center gap-4 px-6 py-32 text-center">
    <h1 class="m-0 text-7xl font-extrabold text-[var(--mn-c-brand-1)]">404</h1>
    <p class="text-[var(--mn-c-text-2)]">The page you requested could not be found.</p>
    <a href="/" class="rounded-lg bg-[var(--mn-c-brand-1)] px-6 py-3 font-semibold text-white no-underline">Return to the homepage</a>
  </div>
</BaseLayout>
