---
import { ClientRouter } from 'astro:transitions'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
import Seo from '../components/Seo.astro'
import '../styles/global.css'
import type { SiteFrontmatter } from '../data/types'
import { THEME_KEY } from '../lib/theme'
import { SITE, buildTitle, buildDescription, autoCrumbs } from '../lib/seo'
import type { Crumb } from '../lib/breadcrumbs'

interface Props {
  title?: string
  description?: string
  frontmatter?: SiteFrontmatter
  ogImage?: string
  ogImageAlt?: string
  publishedAt?: string
  modifiedAt?: string | null
  authorName?: string
  seoTitle?: string          // absolute <title>, bypasses the "| Metanorma" suffix
  crumbs?: Crumb[]           // override; defaults to pathname-derived crumbs
  robots?: string            // override robots meta (default: index,follow)
  editUrl?: string | null    // "Edit this page" link target (GitHub edit URL)
}

const props = Astro.props as Props
const frontmatter = props.frontmatter || {}
const docTitle = props.title || frontmatter.title || ''
const title = props.seoTitle || buildTitle(docTitle)
const description = buildDescription(props.description, frontmatter.description, frontmatter.excerpt)
const canonical = new URL(Astro.url.pathname, Astro.site).toString()
const ogImage = props.ogImage || frontmatter.card_image || null
const publishedAt = props.publishedAt || frontmatter.date || null
const modifiedAt = props.modifiedAt || null
const authorName = props.authorName || frontmatter.author?.name || null
const pathname = Astro.url.pathname
const crumbs = props.crumbs ?? (pathname === '/' ? [] : autoCrumbs(pathname, docTitle))
const editUrl = props.editUrl || null
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,200;12..96,300;12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Hanken+Grotesk:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <Seo
      title={title}
      docTitle={docTitle || SITE.name}
      description={description}
      canonical={canonical}
      type={publishedAt ? 'article' : 'website'}
      image={ogImage}
      imageAlt={props.ogImageAlt}
      publishedAt={publishedAt}
      modifiedAt={modifiedAt}
      authorName={authorName}
      crumbs={crumbs}
      robots={props.robots}
    />
    <ClientRouter />
    <script src="/js/easter-eggs.js" defer is:inline></script>
    <script is:inline define:vars={{ THEME_KEY }}>
      (function(){try{var s=localStorage.getItem(THEME_KEY);var d=window.matchMedia('(prefers-color-scheme: dark)').matches;if(s==='dark'||(s!=='light'&&d))document.documentElement.classList.add('dark')}catch(e){}})()
      document.addEventListener('astro:before-swap',function(ev){if(document.documentElement.classList.contains('dark')){ev.newDocument.documentElement.classList.add('dark')}})
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-[var(--mn-c-bg)] text-[var(--mn-c-text-1)] antialiased transition-colors duration-300">
    <a
      href="#mn-main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[300] focus:rounded-lg focus:bg-[var(--mn-c-brand-1)] focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>
    <Nav />
    <main id="mn-main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // The easter-egg registry — type help() in the console to meet them all.
      window.help = function () {
        console.log('%c Metanorma easter eggs ', 'background:#1a1a2e;color:#c8b8ff;padding:4px 8px;border-radius:4px;font-weight:bold;')
        console.table([
          { egg: 'The lighthouse', where: 'Homepage', how: 'Move to aim · click to kick · hold for SOS · Konami ↑↑↓↓←→←→BA · reduced motion? click to start' },
          { egg: 'Fog & the occasional ship', where: 'Homepage hero', how: 'Just watch the sea for a while' },
          { egg: 'IN FORCE stamp', where: 'Homepage code card', how: 'Already stamped. It means what you think it means' },
          { egg: 'The :hidden: attribute', where: '/hidden/', how: 'The only attribute not in the reference' },
          { egg: 'MN/PN-404', where: '/404.html', how: 'A page not found, expected publication Q3 2099' },
          { egg: 'Annex Z (informative)', where: 'Every docs page', how: 'Scroll to the bottom' },
          { egg: 'Search secrets', where: '⌘K / Ctrl+K', how: 'Rotating placeholders, the secretariat, the drafting committee' },
          { egg: 'Day shift / night shift', where: 'Theme toggle', how: 'Hover it (the lamp knows)' },
          { egg: 'Navigation, as amended', where: 'Mobile menu', how: 'Open the menu below 768px' },
          { egg: 'Please initial each page', where: 'Print', how: '⌘P / Ctrl+P' },
          { egg: 'APPROVED ✓', where: 'Anywhere (keyboard)', how: 'Press A outside an input — a rubber-stamp sweeps the page' },
          { egg: 'Joint Secretariat seal', where: 'Header logo', how: 'Long-press the logo (1.2s) — it spins, the tagline slips' },
          { egg: 'Year time-machine', where: 'Footer copyright', how: 'Tap the year rapidly — cycles back through history (floor: 1947)' },
          { egg: 'Drafting committee', where: 'Any selection', how: 'Select 280+ characters — the committee is convened' },
          { egg: 'PEER REVIEWED', where: 'Code blocks (<pre>)', how: 'Long-press (800ms) inside a code block' },
          { egg: 'help()', where: 'This console', how: 'You already know' },
        ])
        console.log('%c — The Committee ', 'color:#8a86a8;font-style:italic;')
      }
    </script>
  </body>
</html>
