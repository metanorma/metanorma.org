---
import { nav } from '../config/site'
import DarkToggle from './DarkToggle.vue'
import SearchButton from './SearchButton.vue'
import Logo from './Logo.astro'
---

<header class="sticky top-0 z-50 border-b border-[var(--mn-c-divider)] bg-[var(--mn-c-nav-bg)] backdrop-blur-sm">
  <div class="mx-auto flex h-16 max-w-[1440px] items-center gap-6 px-6">
    <a href="/" class="flex-shrink-0">
      <Logo class="h-8" />
    </a>

    <nav class="hidden flex-1 items-center gap-5 md:flex" aria-label="Primary">
      {nav.map((item) => (
        <div class="group relative">
          {item.items ? (
            <>
              <button type="button" class="flex items-center gap-1 border-0 bg-transparent text-sm font-medium text-[var(--mn-c-text-2)] hover:text-[var(--mn-c-brand-1)]">
                {item.text}
                <span class="inline-block h-0 w-0 border-l-[3px] border-r-[3px] border-t-[4px] border-l-transparent border-r-transparent border-t-current"></span>
              </button>
              <div class="invisible absolute left-0 top-full min-w-[200px] rounded-lg border border-[var(--mn-c-divider)] bg-[var(--mn-c-bg-elv)] p-2 opacity-0 shadow-lg transition-all group-hover:visible group-hover:opacity-100">
                {item.items.map((sub) => (
                  <a href={sub.link} class="block rounded px-3 py-1.5 text-sm text-[var(--mn-c-text-2)] no-underline hover:bg-[var(--mn-c-bg-soft)] hover:text-[var(--mn-c-brand-1)]">{sub.text}</a>
                ))}
              </div>
            </>
          ) : (
            <a href={item.link} class="text-sm font-medium text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">{item.text}</a>
          )}
        </div>
      ))}
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <SearchButton client:idle />
      <DarkToggle client:load />
    </div>
  </div>
</header>
