---
interface Props {
  title?: string
  subtitle?: string
  // Extra classes for the <article> element. Pages with a sidebar get
  // the default plain wrapper; standalone pages pass their centering /
  // typography classes (e.g. "mn-rendered mx-auto max-w-3xl px-6 py-12").
  class?: string
  editUrl?: string | null
}
const { title, subtitle, class: className = 'w-full', editUrl = null } = Astro.props
---

<article class={className}>
  <slot name="breadcrumb" />
  {title && (
    <header class="mb-8 border-b border-[var(--mn-c-divider)] pb-4">
      <h1 class="m-0 text-4xl font-extrabold leading-tight tracking-tight">{title}</h1>
      {subtitle && <p class="mt-2 text-[var(--mn-c-text-2)]">{subtitle}</p>}
    </header>
  )}
  <slot />
  {editUrl && (
    <p class="mt-12 border-t border-[var(--mn-c-divider)] pt-6 text-sm text-[var(--mn-c-text-3)]">
      <a href={editUrl} target="_blank" rel="noopener" class="text-[var(--mn-c-brand-1)] no-underline hover:underline">
        Edit this page on GitHub →
      </a>
    </p>
  )}
  <p class="mn-annex-z" aria-hidden="true">
    <strong>Annex Z</strong> (informative) — You found the bottom of the page.
  </p>
</article>
