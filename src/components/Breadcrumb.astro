---
import { buildCrumbs } from '../lib/breadcrumbs'
import type { NavRoot } from '../lib/nav-tree'

// The nav tree comes in as a prop (resolved once by the page for the
// full pathname). Crumbs come from the shared model in lib/breadcrumbs.
interface Props { nav: NavRoot | null; pathname: string }
const { nav, pathname } = Astro.props
const crumbs = buildCrumbs(nav, pathname)
---

{crumbs.length > 0 && (
  <nav aria-label="Breadcrumb" class="mb-4 flex items-center gap-1.5 text-sm text-[var(--mn-c-text-3)]">
    <a href="/" class="no-underline transition-colors hover:text-[var(--mn-c-brand-1)]">Home</a>
    {crumbs.map(crumb => (
      <>
        <svg class="h-3 w-3 text-[var(--mn-c-divider)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        {crumb.isLast ? (
          <span class="font-medium text-[var(--mn-c-text-1)]">{crumb.label}</span>
        ) : (
          <a href={crumb.href} class="no-underline transition-colors hover:text-[var(--mn-c-brand-1)]">{crumb.label}</a>
        )}
      </>
    ))}
  </nav>
)}
