---
import { sidebarFor } from '../config/site'
import { rootLabels } from '../config/labels'
import { sourcePathToUrl } from '../lib/nav-tree'
import type { NavRoot, NavNode } from '../lib/nav-tree'

interface Props { pathname: string }
const { pathname } = Astro.props

function norm(url: string): string {
  return '/' + url.replace(/^\/+|\/+$/g, '') + '/'
}

function findLabel(items: NavNode[], target: string): string | null {
  const targetNorm = norm(target)
  for (const item of items) {
    if (item.file && norm(sourcePathToUrl(item.file)) === targetNorm) {
      return item.title
    }
    if (item.items) {
      const sub = findLabel(item.items, target)
      if (sub) return sub
    }
  }
  return null
}

function resolveLabel(nav: NavRoot | null, cumulative: string, segment: string): string {
  if (rootLabels[segment]) return rootLabels[segment]
  if (!nav) return segment
  const navPath = nav.prefix.replace(/\/+$/g, '')
  if (cumulative === navPath) return nav.title
  return findLabel(nav.items, cumulative) ?? segment
}

const segments = pathname.split('/').filter(Boolean)
const crumbs: { label: string; href: string; isLast: boolean }[] = []

let cumulative = ''
for (let i = 0; i < segments.length; i++) {
  cumulative += '/' + segments[i]
  const nav = sidebarFor(cumulative + '/')
  const label = resolveLabel(nav, cumulative, segments[i])
  crumbs.push({ label, href: cumulative + '/', isLast: i === segments.length - 1 })
}
---

{crumbs.length > 0 && (
  <nav aria-label="Breadcrumb" class="mb-4 flex items-center gap-1.5 text-sm text-[var(--mn-c-text-3)]">
    <a href="/" class="no-underline transition-colors hover:text-[var(--mn-c-brand-1)]">Home</a>
    {crumbs.map(crumb => (
      <>
        <svg class="h-3 w-3 text-[var(--mn-c-divider)]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        {crumb.isLast ? (
          <span class="font-medium text-[var(--mn-c-text-1)]">{crumb.label}</span>
        ) : (
          <a href={crumb.href} class="no-underline transition-colors hover:text-[var(--mn-c-brand-1)]">{crumb.label}</a>
        )}
      </>
    ))}
  </nav>
)}
