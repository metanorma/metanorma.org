---
interface Props { class?: string }
const { class: className = 'h-8' } = Astro.props
---

<>
  <img src="/metanorma-logo_full-light.svg" alt="Metanorma" class={`${className} dark:hidden`} />
  <img src="/metanorma-logo_full-dark.svg" alt="Metanorma" class={`hidden ${className} dark:block`} />
</>
