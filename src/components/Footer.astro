---
import Logo from './Logo.astro'
import { footerColumns } from '../config/site'
const year = new Date().getFullYear()
---

<footer class="border-t border-[var(--mn-c-divider)] bg-[var(--mn-c-bg-soft)]">
  <div class="mx-auto flex max-w-[1440px] flex-col gap-8 px-6 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:justify-between">
      <div>
        <Logo class="mb-2 h-7" />
        <p class="text-sm text-[var(--mn-c-text-3)]">The standard of standards</p>
        <p class="mt-1 max-w-[260px] text-xs leading-relaxed text-[var(--mn-c-text-3)] opacity-80">
          This website is a work in progress, like all good standards.
          Built with Metanorma — we eat our own dog food (ISO-certified).
        </p>
      </div>
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-4">
        {footerColumns.map(column => (
          <div>
            <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--mn-c-text-3)]">{column.title}</h4>
            <ul class="space-y-2 text-sm">
              {column.links.map(link => (
                <li>
                  {link.icon === 'github' ? (
                    <a href={link.link} target="_blank" rel="noopener" aria-label="GitHub" class="inline-flex items-center gap-1.5 text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.4.5 0 5.9 0 12.5c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2.1c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17.3 4.7 18.3 5 18.3 5c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0 0 24 12.5C24 5.9 18.6.5 12 .5z" /></svg>
                      GitHub
                    </a>
                  ) : (
                    <a href={link.link} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener' : undefined} class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">{link.text}</a>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="flex flex-col items-center justify-between gap-4 border-t border-[var(--mn-c-divider)] pt-6 sm:flex-row">
      <p class="text-sm text-[var(--mn-c-text-3)]">&copy; {year} Ribose Group Inc. All rights reserved.</p>
      <div class="flex gap-4 text-sm">
        <a href="https://www.ribose.com/tos" class="text-[var(--mn-c-text-3)] no-underline hover:text-[var(--mn-c-brand-1)]">Terms of Service</a>
        <a href="https://www.ribose.com/privacy" class="text-[var(--mn-c-text-3)] no-underline hover:text-[var(--mn-c-brand-1)]">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
