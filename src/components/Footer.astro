---
import Logo from './Logo.astro'
const year = new Date().getFullYear()
---

<footer class="border-t border-[var(--mn-c-divider)] bg-[var(--mn-c-bg-soft)]">
  <div class="mx-auto flex max-w-[1440px] flex-col gap-8 px-6 py-12">
    <div class="flex flex-col gap-8 md:flex-row md:justify-between">
      <div>
        <Logo class="mb-2 h-7" />
        <p class="text-sm text-[var(--mn-c-text-3)]">The standard of standards</p>
      </div>
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3">
        <div>
          <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--mn-c-text-3)]">Documentation</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/author/" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">Author</a></li>
            <li><a href="/flavors/" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">Flavors</a></li>
            <li><a href="/develop/" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">Develop</a></li>
            <li><a href="/reference/" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">Reference</a></li>
          </ul>
        </div>
        <div>
          <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--mn-c-text-3)]">Resources</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="/install/" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">Install</a></li>
            <li><a href="/software/" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">Software</a></li>
            <li><a href="/blog/" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">Blog</a></li>
            <li><a href="/learn/" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">Learn</a></li>
          </ul>
        </div>
        <div>
          <h4 class="mb-3 text-xs font-semibold uppercase tracking-wider text-[var(--mn-c-text-3)]">Community</h4>
          <ul class="space-y-2 text-sm">
            <li><a href="https://github.com/metanorma" target="_blank" rel="noopener" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">GitHub</a></li>
            <li><a href="https://github.com/metanorma/discussions" target="_blank" rel="noopener" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">Discussions</a></li>
            <li><a href="/about/" class="text-[var(--mn-c-text-2)] no-underline hover:text-[var(--mn-c-brand-1)]">About</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="flex flex-col items-center justify-between gap-4 border-t border-[var(--mn-c-divider)] pt-6 sm:flex-row">
      <p class="text-sm text-[var(--mn-c-text-3)]">&copy; {year} Ribose Group Inc. All rights reserved.</p>
      <div class="flex gap-4 text-sm">
        <a href="https://www.ribose.com/tos" class="text-[var(--mn-c-text-3)] no-underline hover:text-[var(--mn-c-brand-1)]">Terms of Service</a>
        <a href="https://www.ribose.com/privacy" class="text-[var(--mn-c-text-3)] no-underline hover:text-[var(--mn-c-brand-1)]">Privacy Policy</a>
      </div>
    </div>
  </div>
</footer>
