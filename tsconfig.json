{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@assets/*": ["./assets/*"]
    },
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": [".ssg/**/*", "src/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist", ".vitepress/dist"]
}
