{
  "name": "metanorma.org",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "convert": "bundle exec ruby scripts/convert-adoc.rb",
    "clean": "bundle exec ruby scripts/convert-adoc.rb --clean",
    "sync": "rake sync",
    "sync:libs": "rake sync:libs",
    "sync:models": "rake sync:models",
    "sync:clean": "rake sync:clean",
    "predev": "npm run convert",
    "prebuild": "npm run convert",
    "dev": "astro dev",
    "build": "astro build && node scripts/build-og-images.mjs && pagefind --site dist && node scripts/optimize-images.mjs",
    "preview": "astro preview",
    "check": "astro check",
    "check:nav": "node scripts/check-nav.mjs",
    "check:schemas": "node scripts/check-schemas.mjs",
    "build:schemas": "node scripts/build-schemas.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metanorma/metanorma.org.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vue": "^7.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/js-yaml": "^4.0.9",
    "astro": "^7.0.7",
    "js-yaml": "^5.2.1",
    "katex": "^0.17.0",
    "pagefind": "^1.3.0",
    "sharp": "^0.34.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vue": "^3.5.39"
  },
  "dependencies": {
    "shiki": "^4.3.1"
  }
}
