# Code examples rendered as links by coradoc (not real URLs)
.*/http$
.*/PATH$
.*/\.\.\.$
.*/title$
.*/href=$
.*/href$
.*/clause3;table2$

# Backtick-encoded content rendered as URL by coradoc
.*%60.*

# Upstream docs paths
.*/docs/usage$

# Placeholder/empty URLs in documentation
^http://$
^https?://$

# Zero-width space in URLs (rendering artifact)
.*&#x200c;.*

# Empty href attributes
^$

# Absolute self-links cannot be checked before deploy (root-relative
# links are file-checked against dist/ anyway)
https://www.metanorma.org/.*

